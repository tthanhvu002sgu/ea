//@version=5
indicator("The 5 Market Regimes - Probabilistic Engine (3-Body Chaos)", shorttitle="5 Regimes (3-Body)", overlay=false)

// =========================================================================
// KIẾN TRÚC 3 VẬT THỂ & ĐIỂM LAGRANGE (3-BODY CHAOS)
// =========================================================================

// --- Inputs ---
N_base  = input.int(20, "Khung thời gian gốc (Base M)", minval=5)
N_min   = input.int(5,  "N Tối thiểu (Chaos/Lagrange)", minval=2)
N_max   = input.int(50, "N Tối đa (Trending/Surfing)", maxval=200)
len_roc = input.int(5,  "Chu kỳ Đạo hàm (Độ dốc nến)", minval=2)

// Cấp phát tĩnh để tránh lỗi "max_bars_back" khi dùng mảng động
_dummy_c = nz(close[200])
_dummy_v = nz(volume[200])
_dummy_h = nz(high[200])
_dummy_l = nz(low[200])
_dummy_o = nz(open[200])

// --- Hàm Hỗ Trợ (Fuzzy Logic & Math) ---
f_up(x, a, b) => math.max(0.0, math.min(1.0, (x - a) / (b - a)))
f_down(x, a, b) => math.max(0.0, math.min(1.0, (b - x) / (b - a)))
f_tanh(x) =>
    float cx = math.max(-10.0, math.min(10.0, x))
    float e2x = math.exp(2.0 * cx)
    (e2x - 1.0) / (e2x + 1.0)

// --- Hàm Tính Toán Động (Dynamic Length Functions) ---
// Thay thế hàm ta.sma, ta.variance bằng vòng lặp để hỗ trợ 'series int' cho độ dài N động
f_dyn_mean(src, len) =>
    float sum = 0.0
    int l = math.max(1, len)
    for i = 0 to l - 1
        sum += nz(src[i])
    sum / l

f_dyn_variance(src, len) =>
    float mean = f_dyn_mean(src, len)
    float sum_sq = 0.0
    int l = math.max(1, len)
    for i = 0 to l - 1
        sum_sq += math.pow(nz(src[i]) - mean, 2)
    sum_sq / l

f_dyn_stdev(src, len) => math.sqrt(f_dyn_variance(src, len))

// =========================================================================
// 🧮 LỚP 0: ĐO LƯỜNG HỖN LOẠN & CỬA SỔ THÍCH NGHI (CHAOS & ADAPTIVE N)
// =========================================================================
float log_ret = close > 0 and nz(close[1]) > 0 ? math.log(close / close[1]) : 0.0
float ret_2p  = close > 0 and nz(close[2]) > 0 ? math.log(close / close[2]) : 0.0

// MỚI — H dùng N_base cố định, không bị ảnh hưởng bởi adaptive window
float var_1p_stable = ta.variance(log_ret, N_base)
float var_2p_stable = ta.variance(ret_2p,  N_base)
float VR_stable     = var_1p_stable > 0 ? var_2p_stable / (2.0 * var_1p_stable) : 1.0
float H             = math.max(0.1, math.min(0.9, 0.5 * math.log(math.max(VR_stable, 0.01)) / math.log(2) + 0.5))

// Cấp độ hỗn loạn: 1.0 (Maximum Chaos khi H = 0.5) -> 0.0 (Trend Rõ)
float chaos_factor = f_down(math.abs(H - 0.5), 0.0, 0.2) 

// N Thích nghi (Adaptive N): chaos cao thì N lớn hơn để lọc nhiễu tốt hơn, chỉ dùng N nhỏ khi thị trường đang trending rõ.
int N_dyn = int(math.round(N_min + chaos_factor * (N_max - N_min)))

// =========================================================================
// 🧮 LỚP 1: 3 VẬT THỂ HẤP DẪN (FEATURE ENGINEERING VỚI N_DYN)
// =========================================================================

// ☄️ VẬT THỂ 1: LỰC QUÁN TÍNH CHÍNH (Price Action & Trend) - Momentum chuẩn hóa (M)
float mean_ret   = f_dyn_mean(log_ret, N_dyn)
float std_ret    = f_dyn_stdev(log_ret, N_dyn)

// Momentum chuẩn hóa (thay thế S)
// Ý nghĩa: giá hiện tại cách giá N_dyn nến trước bao nhiêu std?
float price_change = close - nz(close[N_dyn])
float M = std_ret * N_dyn > 0 ? price_change / (close * std_ret * math.sqrt(float(N_dyn))) : 0.0
M := math.max(-3.0, math.min(3.0, M))  // clip outlier

// 🌑 VẬT THỂ 2: LỰC CẢN KHÔNG-THỜI GIAN (Volatility Squeeze/Expansion) - BB/ATR
float bb_stdev = f_dyn_stdev(close, N_dyn)
float tr_val   = math.max(math.max(high - low, math.abs(high - nz(close[1]))), math.abs(low - nz(close[1])))
float dyn_atr  = f_dyn_mean(tr_val, N_dyn)
float V        = dyn_atr > 0 ? (2.0 * bb_stdev) / (1.5 * dyn_atr) : 1.0

// 🌍 VẬT THỂ 3: ĐỘNG CƠ XUNG LỰC BÊN NGOÀI (CVD Z-Score Dòng Tiền)
float hl_diff   = high - low
float delta_vol = hl_diff > 0 ? volume * (close - open) / hl_diff : (close > open ? volume : (close < open ? -volume : 0))

// MỚI — baseline tính từ nến CŨ HƠN, không chồng lấn với signal
int signal_len   = math.max(3, int(N_dyn / 3))
int baseline_len = N_dyn

// Signal: trung bình delta_vol của signal_len nến gần nhất
float signal_dv = f_dyn_mean(delta_vol, signal_len)

// Baseline: mean và std của baseline_len nến, bắt đầu từ sau signal window
float sum_base = 0.0
for i = signal_len to signal_len + baseline_len - 1
    sum_base += nz(delta_vol[i])
float mean_base = sum_base / baseline_len

float sum_sq_base = 0.0
for i = signal_len to signal_len + baseline_len - 1
    float diff_b = nz(delta_vol[i]) - mean_base
    sum_sq_base += diff_b * diff_b
float std_base = math.sqrt(sum_sq_base / baseline_len)

float Z = std_base > 0 ? (signal_dv - mean_base) / std_base : 0.0
Z := math.max(-4.0, math.min(4.0, Z))


// =========================================================================
// 🧠 LỚP 2: ĐỘNG CƠ CHẤM ĐIỂM XÁC SUẤT BẰNG FUZZY LOGIC
// =========================================================================

// THÊM 3 score mới
// Regime CHAOS: H gần 0.5, V bình thường, Z yên tĩnh
float score_Chaos = 1.5 * f_down(math.abs(H - 0.5), 0.0, 0.15)  + 1.5 * f_down(math.abs(V - 1.0), 0.0, 0.25)     + 1.5 * f_down(math.abs(Z), 0.0, 0.8)            

// Regime SQUEEZE: mean-reverting (H thấp), volatility nén (V thấp)
float score_Squeeze = 2.0 * f_down(H, 0.35, 0.5)                  + 3.0 * f_down(V, 0.6, 1.0)                     + 1.0 * f_down(math.abs(Z), 0.0, 1.0)         

// Regime TREND: trending (H cao), volatility mở rộng (V cao)
float score_Trend = 2.5 * f_up(H, 0.5, 0.7)                        + 2.0 * f_up(V, 1.0, 1.5)                        + 1.0 * f_up(math.abs(Z), 0.5, 2.0)             

// =========================================================================
// 🌐 THUẬT TOÁN CHUẨN HÓA (SOFTMAX 3 CLASS)
// =========================================================================
float max_score_3 = math.max(score_Chaos, math.max(score_Squeeze, score_Trend))

float e_Chaos   = math.exp(score_Chaos   - max_score_3)
float e_Squeeze = math.exp(score_Squeeze - max_score_3)
float e_Trend   = math.exp(score_Trend   - max_score_3)
float sum_e3    = e_Chaos + e_Squeeze + e_Trend

float P_Chaos   = (e_Chaos   / sum_e3) * 100.0
float P_Squeeze = (e_Squeeze / sum_e3) * 100.0
float P_Trend   = (e_Trend   / sum_e3) * 100.0

// =========================================================================
// 🎯 LỚP 3: BIAS VECTOR (THAY THẾ DIRECTIONAL SCORING)
// =========================================================================
// Bias chuẩn hóa — kết hợp Z và M, weighted by trend confidence
float M_norm    = f_tanh(M)                         // ép [-1, 1]
float Z_norm    = f_tanh(Z / 2.0)                   // scale Z xuống rồi ép [-1, 1]
float bias_raw  = 0.6 * Z_norm + 0.4 * M_norm          // Z quan trọng hơn M
float confidence = P_Trend / 100.0                      // 0.0 đến 1.0
float Bias      = bias_raw * confidence                 // triệt tiêu khi không trend


// =========================================================================
// 🚦 LỚP 4: BỘ LỌC CHU KỲ RE-PAINT (PHASE FILTER)
// =========================================================================
var int active_regime = 0
float current_max_prob = math.max(P_Chaos, math.max(P_Squeeze, P_Trend))
int current_regime = P_Trend > P_Squeeze and P_Trend > P_Chaos ? 3 : (P_Squeeze > P_Chaos ? 2 : 1)
if current_max_prob > 50.0 or active_regime == 0
    active_regime := current_regime

// =========================================================================
// 📈 LƯỚT SÓNG ĐIỂM LAGRANGE (HIỆU ỨNG CÁNH BƯỚM)
// =========================================================================
float slope_Trend   = ta.linreg(P_Trend, len_roc, 1) - ta.linreg(P_Trend, len_roc, 2)
float slope_Squeeze = ta.linreg(P_Squeeze, len_roc, 1) - ta.linreg(P_Squeeze, len_roc, 2)
float slope_Chaos   = ta.linreg(P_Chaos, len_roc, 1) - ta.linreg(P_Chaos, len_roc, 2)
float slope_Z       = ta.linreg(Z, len_roc, 1) - ta.linreg(Z, len_roc, 2)

// 🌌 TÌM ĐIỂM LAGRANGE (Vùng Cân Bằng Lực)
// Khi P_Squeeze vượt 70% và dao động thu hẹp
bool is_lagrange = P_Squeeze > 70.0 and V < 1.0 and math.abs(Z) < 0.8

// 🦋 HIỆU ỨNG CÁNH BƯỚM (Butterfly Breakout)
bool butterfly_buy  = (is_lagrange[1] or is_lagrange[2]) and Z > 1.0 and slope_Z > 0 and close > open
bool butterfly_sell = (is_lagrange[1] or is_lagrange[2]) and Z < -1.0 and slope_Z < 0 and close < open


// =========================================================================
// 🎨 MÀU SẮC & DASHBOARD
// =========================================================================

// Màu cơ bản cho Bias
color col_Markup   = color.new(#00E676, 10)
color col_Markdown = color.new(#FF1744, 10)

// Màu cho 3 class Regime
color col_Trend   = color.new(#FF9100, 10) // Cam
color col_Squeeze = color.new(#2962FF, 10) // Xanh dương
color col_Chaos   = color.new(#9E9E9E, 30) // Xám

color CLR_BG       = color.new(#0D1117, 10)
color CLR_BG_ROW   = color.new(#161B22, 10)
color CLR_BORDER   = color.new(#30363D, 0)
color CLR_TEXT     = color.new(#E6EDF3, 0)
color CLR_DIM      = color.new(#8B949E, 0)

// Phân loại Bias label
string bias_label = Bias > 0.3 ? "▲ LONG" : (Bias < -0.3 ? "▼ SHORT" : "● NEUTRAL")
color  bias_color = Bias > 0.3 ? col_Markup : (Bias < -0.3 ? col_Markdown : col_Chaos)

float max_P = -1.0
color dom_color = na

float second_P = -1.0
color second_color = na

if P_Trend > max_P
    second_P := max_P
    second_color := dom_color
    max_P := P_Trend
    dom_color := bias_color
else if P_Trend > second_P
    second_P := P_Trend
    second_color := bias_color

if P_Squeeze > max_P
    second_P := max_P
    second_color := dom_color
    max_P := P_Squeeze
    dom_color := col_Squeeze
else if P_Squeeze > second_P
    second_P := P_Squeeze
    second_color := col_Squeeze

if P_Chaos > max_P
    second_P := max_P
    second_color := dom_color
    max_P := P_Chaos
    dom_color := col_Chaos
else if P_Chaos > second_P
    second_P := P_Chaos
    second_color := col_Chaos

// Dashboard UI Filter
string dash_regime_name = active_regime == 3 ? "📈 XU HƯỚNG (TREND)" : (active_regime == 2 ? "🔋 SQUEEZE (NÉN)" : "🌀 CHAOS (NHIỄU)")
string dash_action      = active_regime == 3 ? "→ Lướt theo Bias" : (active_regime == 2 ? "→ Chờ đợi bùng nổ" : "→ Đợi cấu trúc rõ hơn")
color  dash_color       = active_regime == 3 ? bias_color : (active_regime == 2 ? col_Squeeze : col_Chaos)

// --- Tô màu nến biểu đồ chính (barcolor) để dễ backtest ---
barcolor(dash_color, title="Candle Colors")

// --- Hiển thị sub-window cho 2 xác suất cao nhất ---
// Cột xác suất lớn nhất (cột cao hơn)
plot(max_P, title="#1 Probability", color=color.new(dom_color, 20), style=plot.style_columns, linewidth=4)
// Cột xác suất thứ 2 đè lên (cột thấp hơn, che phần dưới của cột lớn)
plot(second_P, title="#2 Probability", color=color.new(second_color, 0), style=plot.style_columns, linewidth=4)

hline(50, title="50% Threshold", color=color.new(color.gray, 50), linestyle=hline.style_dashed)
hline(75, title="75% Threshold", color=color.new(color.gray, 80), linestyle=hline.style_dotted)

string signal_text = butterfly_buy ? "🦋 BUTTERFLY: Lướt Mua" : (butterfly_sell ? "🦋 BUTTERFLY: Lướt Bán" : (is_lagrange ? "🌌 TẠI ĐIỂM SQUEEZE" : "Bias: " + bias_label))
color  signal_clr  = butterfly_buy ? col_Markup : (butterfly_sell ? col_Markdown : (is_lagrange ? color.new(#AB47BC, 0) : bias_color))

var table HUD = table.new(position.bottom_right, 3, 16, bgcolor=CLR_BG, border_color=CLR_BORDER, border_width=1, frame_color=CLR_BORDER, frame_width=1)

if barstate.islast
    table.cell(HUD, 0, 0, "🧠 MARKET REGIME (3-BODY CHAOS)", text_color=color.new(#FFD600, 0), text_size=size.normal, bgcolor=color.new(#1565C0, 30), text_halign=text.align_center)
    table.merge_cells(HUD, 0, 0, 2, 0)

    table.cell(HUD, 0, 1, dash_regime_name + "\n" + str.tostring(max_P, "#.#") + "% xác suất", text_color=dash_color, text_size=size.normal, bgcolor=color.new(dash_color, 88), text_halign=text.align_center)
    table.merge_cells(HUD, 0, 1, 2, 1)

    table.cell(HUD, 0, 2, dash_action, text_color=dash_color, text_size=size.small, bgcolor=CLR_BG, text_halign=text.align_center)
    table.merge_cells(HUD, 0, 2, 2, 2)

    table.cell(HUD, 0, 3, signal_text, text_color=color.white, text_size=size.small, bgcolor=color.new(signal_clr, 50), text_halign=text.align_center)
    table.merge_cells(HUD, 0, 3, 2, 3)

    table.cell(HUD, 0, 4, "── Xác suất Regime ──", text_color=CLR_DIM, text_size=size.tiny, bgcolor=CLR_BG, text_halign=text.align_center)
    table.merge_cells(HUD, 0, 4, 2, 4)

    table.cell(HUD, 0, 5, "📈 Trend (Xu hướng)", text_color=col_Trend, text_size=size.small, bgcolor=CLR_BG_ROW, text_halign=text.align_left)
    table.cell(HUD, 1, 5, str.tostring(P_Trend, "#.#") + "%", text_color=col_Trend, text_size=size.small, bgcolor=CLR_BG_ROW, text_halign=text.align_right)
    table.cell(HUD, 2, 5, slope_Trend > 0 ? "▲" : (slope_Trend < 0 ? "▼" : "►"), text_color=slope_Trend > 0 ? col_Trend : CLR_DIM, text_size=size.small, bgcolor=CLR_BG_ROW, text_halign=text.align_center)

    table.cell(HUD, 0, 6, "🔋 Squeeze (Nén)", text_color=col_Squeeze, text_size=size.small, bgcolor=CLR_BG_ROW, text_halign=text.align_left)
    table.cell(HUD, 1, 6, str.tostring(P_Squeeze, "#.#") + "%", text_color=col_Squeeze, text_size=size.small, bgcolor=CLR_BG_ROW, text_halign=text.align_right)
    table.cell(HUD, 2, 6, slope_Squeeze > 0 ? "▲" : (slope_Squeeze < 0 ? "▼" : "►"), text_color=slope_Squeeze > 0 ? col_Squeeze : CLR_DIM, text_size=size.small, bgcolor=CLR_BG_ROW, text_halign=text.align_center)

    table.cell(HUD, 0, 7, "🌀 Chaos (Nhiễu)", text_color=col_Chaos, text_size=size.small, bgcolor=CLR_BG_ROW, text_halign=text.align_left)
    table.cell(HUD, 1, 7, str.tostring(P_Chaos, "#.#") + "%", text_color=col_Chaos, text_size=size.small, bgcolor=CLR_BG_ROW, text_halign=text.align_right)
    table.cell(HUD, 2, 7, slope_Chaos > 0 ? "▲" : (slope_Chaos < 0 ? "▼" : "►"), text_color=slope_Chaos > 0 ? col_Chaos : CLR_DIM, text_size=size.small, bgcolor=CLR_BG_ROW, text_halign=text.align_center)

    table.cell(HUD, 0, 8, "── Lực Nội Tại (3 Bodies) ──", text_color=CLR_DIM, text_size=size.tiny, bgcolor=CLR_BG, text_halign=text.align_center)
    table.merge_cells(HUD, 0, 8, 2, 8)

    table.cell(HUD, 0, 9, "Chu kỳ N Động", text_color=color.new(#00E5FF,0), text_size=size.small, bgcolor=CLR_BG_ROW, text_halign=text.align_left)
    table.cell(HUD, 1, 9, str.tostring(N_dyn) + " nến", text_color=color.white, text_size=size.small, bgcolor=CLR_BG_ROW, text_halign=text.align_center)
    table.cell(HUD, 2, 9, "Chaos=" + str.tostring(chaos_factor, "#.##"), text_color=CLR_DIM, text_size=size.tiny, bgcolor=CLR_BG_ROW, text_halign=text.align_right)

    table.cell(HUD, 0, 10, "Xu hướng (H)", text_color=CLR_DIM, text_size=size.small, bgcolor=CLR_BG_ROW, text_halign=text.align_left)
    table.cell(HUD, 1, 10, H > 0.6 ? "Có trend rõ" : (H < 0.45 ? "Chop" : "Chưa rõ"), text_color=H > 0.6 ? col_Trend : (H < 0.45 ? col_Chaos : col_Squeeze), text_size=size.small, bgcolor=CLR_BG_ROW, text_halign=text.align_center)
    table.cell(HUD, 2, 10, str.tostring(H, "#.##"), text_color=CLR_DIM, text_size=size.tiny, bgcolor=CLR_BG_ROW, text_halign=text.align_right)

    table.cell(HUD, 0, 11, "Momentum (M)", text_color=CLR_DIM, text_size=size.small, bgcolor=CLR_BG_ROW, text_halign=text.align_left)
    table.cell(HUD, 1, 11, M > 1.0 ? "Nghiêng tăng" : (M < -1.0 ? "Nghiêng giảm" : "Cân bằng"), text_color=M > 1.0 ? col_Markup : (M < -1.0 ? col_Markdown : col_Chaos), text_size=size.small, bgcolor=CLR_BG_ROW, text_halign=text.align_center)
    table.cell(HUD, 2, 11, str.tostring(M, "#.##"), text_color=CLR_DIM, text_size=size.tiny, bgcolor=CLR_BG_ROW, text_halign=text.align_right)

    table.cell(HUD, 0, 12, "Biến động (V)", text_color=CLR_DIM, text_size=size.small, bgcolor=CLR_BG_ROW, text_halign=text.align_left)
    table.cell(HUD, 1, 12, V > 1.2 ? "Vượt nén" : (V < 1.0 ? "Nén chặt" : "Bình thường"), text_color=V > 1.2 ? col_Markup : (V < 1.0 ? col_Squeeze : col_Chaos), text_size=size.small, bgcolor=CLR_BG_ROW, text_halign=text.align_center)
    table.cell(HUD, 2, 12, str.tostring(V, "#.##"), text_color=CLR_DIM, text_size=size.tiny, bgcolor=CLR_BG_ROW, text_halign=text.align_right)

    table.cell(HUD, 0, 13, "Dòng tiền (Z)", text_color=CLR_DIM, text_size=size.small, bgcolor=CLR_BG_ROW, text_halign=text.align_left)
    table.cell(HUD, 1, 13, Z > 1.0 ? "Tiền vào" : (Z < -1.0 ? "Tiền ra" : "Trung"), text_color=Z > 1.0 ? col_Markup : (Z < -1.0 ? col_Markdown : col_Chaos), text_size=size.small, bgcolor=CLR_BG_ROW, text_halign=text.align_center)
    table.cell(HUD, 2, 13, str.tostring(Z, "#.##"), text_color=CLR_DIM, text_size=size.tiny, bgcolor=CLR_BG_ROW, text_halign=text.align_right)

    table.cell(HUD, 0, 14, "BIAS (Vector)", text_color=color.new(#FFD600,0), text_size=size.small, bgcolor=CLR_BG_ROW, text_halign=text.align_left)
    table.cell(HUD, 1, 14, bias_label, text_color=bias_color, text_size=size.small, bgcolor=CLR_BG_ROW, text_halign=text.align_center)
    table.cell(HUD, 2, 14, str.tostring(Bias, "#.##"), text_color=CLR_DIM, text_size=size.tiny, bgcolor=CLR_BG_ROW, text_halign=text.align_right)
