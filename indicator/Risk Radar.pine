// This Pine Script™ code is subject to the terms of the Mozilla Public License 2.0
// https://mozilla.org/MPL/2.0/
// © Risk Radar - Volatility Assessment Indicator
// Công thức: Risk_Score = (High - Low) / SMA(High - Low, Period)

//@version=6
indicator("Risk Radar", shorttitle="RiskRadar", overlay=false, precision=2)

//=============================================================================
// INPUT PARAMETERS
//=============================================================================

// === CORE SETTINGS ===
inp_period      = input.int(20, "SMA Period (Average Range)", minval=2, maxval=100, group="Core Settings")
inp_show_levels = input.bool(true, "Show Risk Levels (1x, 2x, 4x)", group="Display")

// === COLORS ===
color_0star = input.color(color.new(#00E676, 0), "Normal (Green)", group="Colors")
color_1star = input.color(color.new(#FFEB3B, 0), "Low Risk (Yellow)", group="Colors")
color_2star = input.color(color.new(#FF9800, 0), "Medium-Low (Orange)", group="Colors")
color_3star = input.color(color.new(#FF5722, 0), "Medium (Deep Orange)", group="Colors")
color_4star = input.color(color.new(#F44336, 0), "High Risk (Red)", group="Colors")
color_5star = input.color(color.new(#B71C1C, 0), "EXTREME (Dark Red)", group="Colors")

//=============================================================================
// CALCULATIONS
//=============================================================================

// Current bar range
current_range = high - low

// SMA of range (Average True Range simplified)
avg_range = ta.sma(current_range, inp_period)

// Risk Score = Current Range / Average Range
risk_score = avg_range > 0 ? current_range / avg_range : 1.0

//=============================================================================
// RISK LEVEL CALCULATION
//=============================================================================

// Determine risk level based on risk score
// k < 1.5: 0 (Normal)
// k < 2.0: 1
// k < 2.5: 2
// k < 3.0: 3
// k < 4.0: 4
// k >= 4.0: 5 (Extreme)

get_risk_level(score) =>
    int result = 0
    if score < 1.5
        result := 0
    else if score < 2.0
        result := 1
    else if score < 2.5
        result := 2
    else if score < 3.0
        result := 3
    else if score < 4.0
        result := 4
    else
        result := 5
    result

risk_level = get_risk_level(risk_score)

//=============================================================================
// COLOR DETERMINATION
//=============================================================================

get_level_color(level) =>
    color result = color_0star
    switch level
        0 => result := color_0star
        1 => result := color_1star
        2 => result := color_2star
        3 => result := color_3star
        4 => result := color_4star
        5 => result := color_5star
    result

bar_color = get_level_color(risk_level)

//=============================================================================
// PLOTTING - HISTOGRAM (COLORS ONLY)
//=============================================================================

// Risk Score Histogram with dynamic color
plot(risk_score, "Risk Score", bar_color, linewidth=3, style=plot.style_histogram)

// Zero line
hline(0, "Zero", color.new(color.gray, 80))

// Risk levels
h1 = hline(inp_show_levels ? 1.0 : na, "Normal (1x)", color.new(color.gray, 50), hline.style_dotted)
h2 = hline(inp_show_levels ? 2.0 : na, "Medium (2x)", color.new(color.orange, 50), hline.style_dotted)
h3 = hline(inp_show_levels ? 4.0 : na, "Extreme (4x)", color.new(color.red, 50), hline.style_dotted)

// Fill between levels for visual guidance
fill(h1, h2, color.new(color.yellow, 90), title="Low Risk Zone")
fill(h2, h3, color.new(color.orange, 90), title="Medium Risk Zone")

//=============================================================================
// ALERTS
//=============================================================================

alertcondition(risk_level >= 5 and risk_level[1] < 5, 
               "EXTREME Risk", 
               "RISK RADAR: EXTREME Risk! Score = {{plot_0}}")

alertcondition(risk_level >= 3 and risk_level[1] < 3, 
               "Medium Risk", 
               "RISK RADAR: Medium Risk Detected! Score = {{plot_0}}")

alertcondition(risk_level >= 4 and risk_level[1] < 4, 
               "High Risk", 
               "RISK RADAR: High Risk! Score = {{plot_0}}")

alertcondition(risk_level == 0 and risk_level[1] > 0, 
               "Risk Normalized", 
               "RISK RADAR: Risk returned to Normal")

//=============================================================================
// BACKGROUND HIGHLIGHT FOR HIGH RISK
//=============================================================================

// Subtle background color for high risk periods
bg_color = risk_level >= 4 ? color.new(color.red, 90) : 
           risk_level >= 3 ? color.new(color.orange, 95) : na
           
bgcolor(bg_color, title="Risk Background")
